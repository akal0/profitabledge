{
  "name": "server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "clean:next": "node -e \"require('node:fs').rmSync('.next', { recursive: true, force: true })\"",
    "build": "bun run clean:next && next build",
    "start": "next start",
    "ai:validate:deterministic": "bun run src/scripts/validate-ai-regressions.ts",
    "ai:validate:assistant": "bun run src/scripts/validate-assistant-regressions.ts",
    "ai:validate:plan": "bun run src/scripts/validate-plan-suite.ts",
    "ai:validate:query": "bun run src/scripts/validate-query-matrix.ts",
    "mt5:backfill": "bun run src/scripts/backfill-mt5-trades.ts",
    "billing:backfill-stripe-customers": "bun run src/scripts/backfill-stripe-billing-customers.ts",
    "billing:apply-stripe-primary-migration": "bun run src/scripts/apply-stripe-primary-billing-migration.ts",
    "billing:export-stripe-migration": "bun run src/scripts/export-stripe-billing-migration.ts",
    "billing:export-payment-data-mapping": "bun run src/scripts/export-stripe-payment-data-mapping.ts",
    "billing:finalize-stripe-cutover": "bun run src/scripts/finalize-stripe-billing-cutover.ts",
    "billing:prepare-stripe-beta-cutover": "bun run src/scripts/prepare-stripe-beta-billing-cutover.ts",
    "mt5:mock-sync": "bun run src/scripts/mock-mt5-worker-sync.ts",
    "price:dedupe": "bun run src/scripts/dedupe-historical-prices.ts",
    "price:prune": "bun run src/scripts/prune-price-data.ts",
    "security:reencrypt-secrets": "bun run src/scripts/re-encrypt-secrets.ts",
    "db:check-migrations": "bun run src/scripts/check-migration-integrity.ts",
    "db:push": "../../node_modules/.bin/drizzle-kit push",
    "db:rename-ai-action-log-indexes": "bun run src/scripts/rename-ai-action-log-indexes.ts",
    "db:find-duplicate-indexes": "bun run src/scripts/find-duplicate-indexes.ts",
    "db:ensure-notifications": "bun run src/scripts/ensure-notifications-schema.ts",
    "db:studio": "../../node_modules/.bin/drizzle-kit studio",
    "db:generate": "../../node_modules/.bin/drizzle-kit generate",
    "db:migrate": "../../node_modules/.bin/drizzle-kit migrate",
    "duka:download": "bun run src/scripts/fetch-dukas-ticks.ts",
    "seed:views": "bun run src/scripts/seed-views.ts",
    "reseed:views": "bun run src/scripts/reseed-views.ts",
    "check-types": "node ../../scripts/run-tsc-check.mjs tsconfig.json",
    "lint": "bun run check-types",
    "sync:worker": "bun run src/scripts/run-sync-scheduler.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/openai": "^3.0.41",
    "@better-auth/passkey": "^1.5.6",
    "@google/generative-ai": "^0.24.1",
    "@neondatabase/serverless": "^1.0.1",
    "@polar-sh/sdk": "^0.46.4",
    "@profitabledge/contracts": "workspace:*",
    "@profitabledge/platform": "workspace:*",
    "@trpc/client": "^11.4.2",
    "@trpc/server": "^11.4.2",
    "ai": "^6.0.116",
    "better-auth": "^1.5.6",
    "bufferutil": "^4.1.0",
    "cli-highlight": "^2.1.11",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.45.1",
    "dukascopy-node": "^1.43.0",
    "fast-xml-parser": "^5.5.5",
    "next": "15.5.9",
    "prettier": "2.8.8",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "stripe": "^20.4.1",
    "ws": "^8.18.3",
    "xlsx": "^0.18.5",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "typescript": "^5",
    "@types/bun": "^1.2.6",
    "drizzle-kit": "^0.31.8",
    "@types/ws": "^8.18.1"
  }
}
