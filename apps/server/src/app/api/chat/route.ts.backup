/**
 * Trading Insights AI Chat API Route
 * 
 * Handles streaming chat responses with intent routing and action handlers.
 */

import { streamText } from "ai";
import { createGoogleGenerativeAI } from "@ai-sdk/google";
import { NextRequest } from "next/server";
import { auth } from "../../../lib/auth";
import { routeIntent } from "../../../lib/ai/intent-router";
import { executeActionWithFallback } from "../../../lib/ai/action-handlers";
import { SYSTEM_PROMPT } from "../../../lib/ai/intent-definitions";

const google = createGoogleGenerativeAI({
  apiKey: process.env.GEMINI_API_KEY || "",
});

export async function POST(request: NextRequest) {
  try {
    // 1. Authenticate user
    const session = await auth.api.getSession({
      headers: request.headers,
    });

    if (!session) {
      return new Response("Unauthorized", { status: 401 });
    }

    // 2. Parse request body
    const body = await request.json();
    const { messages, accountId } = body;

    if (!messages || !Array.isArray(messages)) {
      return new Response("Invalid request: messages array required", {
        status: 400,
      });
    }

    // 3. Get the last user message
    const lastMessage = messages[messages.length - 1];
    if (!lastMessage || lastMessage.role !== "user") {
      return new Response("Invalid request: last message must be from user", {
        status: 400,
      });
    }

    const userMessage = lastMessage.content;

    // 4. Check if this is a calculation/aggregation query (bypass intent routing)
    const isCalculationQuery = /\b(sum|total|average|avg|highest|lowest|max|min|count|between|when|where|<|>)\b/i.test(userMessage);
    
    // 5. Try to route the intent (skip for calculation queries)
    let routeResult = null;
    if (!isCalculationQuery) {
      routeResult = await routeIntent(userMessage, accountId);
      console.log("[Chat API] Routing result:", JSON.stringify({
        message: userMessage,
        intent: routeResult?.intent?.name,
        confidence: routeResult?.confidence,
        handler: routeResult?.intent?.handler,
      }));
    } else {
      console.log("[Chat API] Detected calculation query - skipping intent routing");
    }

    // 6. Try to execute with dynamic query fallback
    console.log("[Chat API] Executing handler with fallback");
    try {
      const result = await executeActionWithFallback(userMessage, routeResult, {
        userId: session.user.id,
        accountId,
      });

      if (result.success) {
        // Return direct response for structured insights
        return new Response(result.message, {
          headers: {
            "Content-Type": "text/plain; charset=utf-8",
          },
        });
      } else {
        // Handler failed, fall back to streaming AI
        console.warn("Handler failed:", result.message);
      }
    } catch (error) {
      console.error("Error executing handler:", error);
      // Fall through to AI streaming
    }

    // 6. Fall back to streaming AI response for general questions
    const result = streamText({
      model: google("gemini-2.5-flash"),
      system: SYSTEM_PROMPT,
      messages: messages.map((m: any) => ({
        role: m.role,
        content: m.content,
      })),
    });

    return result.toTextStreamResponse();
  } catch (error) {
    console.error("Chat API error:", error);
    return new Response("Internal server error", { status: 500 });
  }
}
